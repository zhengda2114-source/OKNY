<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>簡便 HTML 即時預覽器</title>
    <style>
        body {
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            font-family: sans-serif;
        }
        header {
            background: #333;
            color: white;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .container {
            display: flex;
            flex: 1;
            overflow: hidden;
        }
        textarea, iframe {
            flex: 1;
            border: none;
            outline: none;
        }
        textarea {
            padding: 15px;
            background: #282c34;
            color: #abb2bf;
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            resize: none;
            border-right: 2px solid #444;
        }
        iframe {
            background: white;
        }
        .label {
            position: absolute;
            background: rgba(0,0,0,0.5);
            color: white;
            padding: 2px 8px;
            font-size: 12px;
            pointer-events: none;
        }
    </style>
</head>
<body>

<header>
    <div>HTML 即時預覽器</div>
    <div style="font-size: 12px;">輸入後右側將自動更新</div>
</header>

<div class="container">
    <div style="position: relative; flex: 1; display: flex;">
        <span class="label">編輯區 (HTML/CSS/JS)</span>
        <textarea id="code" placeholder="在此輸入 HTML 程式碼..."></textarea>
    </div>
    
    <div style="position: relative; flex: 1; display: flex;">
        <span class="label" style="right: 0;">預覽結果</span>
        <iframe id="preview"></iframe>
    </div>
</div>

<script>
    const textarea = document.getElementById('code');
    const iframe = document.getElementById('preview');

    // 預設內容
    const defaultCode = `<!DOCTYPE html>
<html>
<head>
  <style>
    h1 { color: #4A90E2; }
    body { font-family: sans-serif; text-align: center; padding-top: 50px; }
  </style>
</head>
<body>
  <h1>Hello Okinawa!</h1>
  <p>這是一個簡單的即時預覽工具。</p>
  <button onclick="alert('測試成功！')">點我測試 JS</button>
</body>
</html>`;

    textarea.value = defaultCode;

    function updatePreview() {
        const doc = iframe.contentDocument || iframe.contentWindow.document;
        doc.open();
        doc.write(textarea.value);
        doc.close();
    }

    // 監聽輸入事件，達成即時更新
    textarea.addEventListener('input', updatePreview);

    // 初始載入
    updatePreview();
</script>

</body>
</html>
